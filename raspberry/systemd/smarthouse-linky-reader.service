[Unit]
Description=SmartHouse Linky TIC reader
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/smarthouse/raspberry
ExecStart=/usr/bin/python3 /opt/smarthouse/raspberry/linky_reader.py
Restart=always
RestartSec=5
User=adrien
Group=adrien

[Install]
WantedBy=multi-user.target
